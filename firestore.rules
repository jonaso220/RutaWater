rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the authenticated user belongs to the given group
    function isGroupMember(groupId) {
      return groupId != null
        && groupId != ''
        && exists(/databases/$(database)/documents/groups/$(groupId))
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }

    // Helper: get the user's groupId from their user doc
    function userGroupId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.groupId;
    }

    // Users collection: each user can only read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Groups: owner can write, members can read, any authenticated user can read for joining
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.owner == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.owner == request.auth.uid;
    }

    // Clients: user owns doc (userId == auth.uid) OR user is member of the doc's group
    match /clients/{clientId} {
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || isGroupMember(resource.data.groupId));
      allow create: if request.auth != null
        && (request.resource.data.userId == request.auth.uid
            || isGroupMember(request.resource.data.groupId));
      allow update: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || isGroupMember(resource.data.groupId));
      allow delete: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || isGroupMember(resource.data.groupId));
    }

    // Debts: user owns doc (userId == auth.uid) OR user is member of the doc's group
    match /debts/{debtId} {
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || isGroupMember(resource.data.groupId));
      allow create: if request.auth != null
        && (request.resource.data.userId == request.auth.uid
            || isGroupMember(request.resource.data.groupId));
      allow update: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || isGroupMember(resource.data.groupId));
      allow delete: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || isGroupMember(resource.data.groupId));
    }

    // Transfers: user owns doc (userId == auth.uid) OR user is member of the doc's group
    match /transfers/{transferId} {
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || isGroupMember(resource.data.groupId));
      allow create: if request.auth != null
        && (request.resource.data.userId == request.auth.uid
            || isGroupMember(request.resource.data.groupId));
      allow update: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || isGroupMember(resource.data.groupId));
      allow delete: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || isGroupMember(resource.data.groupId));
    }

    // Settings: user can only access their own settings doc
    match /settings/{settingsId} {
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || settingsId == request.auth.uid);
      allow create: if request.auth != null
        && (request.resource.data.userId == request.auth.uid
            || settingsId == request.auth.uid);
      allow update: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || settingsId == request.auth.uid);
      allow delete: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || settingsId == request.auth.uid);
    }
  }
}
